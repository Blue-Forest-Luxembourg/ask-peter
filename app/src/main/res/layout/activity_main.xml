<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117">

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🤖 Ask Peter"
        android:textColor="#58A6FF"
        android:textSize="36sp"
        android:fontFamily="sans-serif-medium"
        android:layout_marginTop="80dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your snarky AI advisor"
        android:textColor="#8B949E"
        android:textSize="16sp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Response card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/responseCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        app:cardBackgroundColor="#161B22"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:strokeColor="#30363D"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/responseText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap the button or shake your phone.\nI have opinions."
            android:textColor="#E6EDF3"
            android:textSize="22sp"
            android:textAlignment="center"
            android:lineSpacingMultiplier="1.3"
            android:padding="32dp"
            android:fontFamily="sans-serif-light" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Ask button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/askButton"
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:text="Ask Peter"
        android:textSize="18sp"
        android:textColor="#FFFFFF"
        android:paddingHorizontal="48dp"
        android:layout_marginBottom="60dp"
        app:backgroundTint="#238636"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Shake hint -->
    <TextView
        android:id="@+id/shakeHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="or shake your phone"
        android:textColor="#484F58"
        android:textSize="13sp"
        android:layout_marginBottom="36dp"
        app:layout_constraintBottom_toTopOf="@id/askButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Footer -->
    <TextView
        android:id="@+id/footerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Built by Peter himself • saypeter.com"
        android:textColor="#30363D"
        android:textSize="11sp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
